---
import CardLabel from "../Card-label.astro";
import Card from "../Card.astro";
import video from "../../images/homepage/physical-manifestation.webm";
import { Image } from "astro:assets";
import gif from "../../images/homepage/physical-manifestation.png";

const title = "Critical Images";
const description = "asdf";
const year = "2023";
const types = [
  { text: "Branding", special: false },
  { text: "Speculative", special: false },
];
const hasVideo = true;
const alt =
  "3D text which reads the Designer likewise becomes the physical manifestation of the work";
---

<Card
  size="small"
  href="projects/critical-images"
  title={title}
  types={types}
  year={year}
  myColor="mediumspringgreen"
>
  <div class="video hidden">
    <video
      class="transition-all"
      playsinline
      muted
      loop
      preload="none"
      data-lazy-video
    >
      <source
        src={video}
        type="video/webm"
      />
    </video>
  </div>
  <div class="gif block">
    <Image
      src={gif}
      alt={alt}
      class="image-center"
      loading="lazy"
      widths={[320, 480, 640, 960]}
      sizes="(min-width: 1536px) 500px, (min-width: 768px) 50vw, 100vw"
    />
  </div>
</Card>
