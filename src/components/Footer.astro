---
import Link from "./Link.astro";
import SectionHeader from "./SectionHeader.astro";

const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1); // remove the first "/"

const year = new Date().getFullYear();
---

<div
  class="h-full site-padding pb-4 bg-purewhite text-sm border-t border-dashed"
>
  <div class="mx-auto">
    <!-- <div class="pt-6">
      <SectionHeader text="Links" />
    </div> -->
    <div class="flex flex-wrap justify-between pt-2">
      <div class="">
        <div
          class="flex justify-start sm:justify-between flex-wrap gap-y-4 py-4 gap-8"
        >
          <div class="">
            <a
              class="underline hover:text-accent-blue"
              href="https://www.instagram.com/briansekelsky/">Instagram</a
            >
          </div>
          <div>
            <a
              class="underline hover:text-accent-blue"
              href="https://open.spotify.com/artist/4GYawQUhnxYepBC7WhUJ4N?si=UOrw0Pc-SQOmT_3K44T8Xg"
              >Spotify</a
            >
          </div>
          <div>
            <a
              class="underline hover:text-accent-blue"
              href="https://www.youtube.com/channel/UCiHaEMWLCmFCeUkskrNeObQ"
              >Youtube</a
            >
          </div>
          <div>
            <a
              class="underline hover:text-accent-blue"
              href="https://www.linkedin.com/in/brian-sekelsky/">LinkedIn</a
            >
          </div>
          <div>
            <a
              class="underline hover:text-accent-blue"
              href="https://www.are.na/brian-sekelsky">Arena</a
            >
          </div>
          <!-- <div>
            <Link
              href="https://bsky.app/profile/briansekelsky.bsky.social"
              name="Bluesky"
              footer="true"
            />
          </div> -->
        </div>
      </div>
      <div class="sm:py-4">
        © <span id="year"></span> Brian Sekelsky
      </div>
    </div>
  </div>
</div>

<script>
  document.getElementById("year").innerHTML = new Date().getFullYear();
</script>
