---
import NavLink from "./Nav-link.astro";
---

<nav class="nav-load-in border-b bg-purewhite text-black">
  <div class="mx-auto">
    <div
      class="flex flex-wrap justify-between gap-4 lg:flex-nowrap p-4 py-8 pb-6 site-padding"
    >
      <div class="w-full">
        <a
          href="/#"
          class="w-full bold lg:first:ml-0 flex justify-start hover:underline transition-all dark:text-dark-text"
          >Brian Sekelsky</a
        >
      </div>
      <div
        class="flex flex-wrap justify-start lg:justify-end gap-8 pt-2 sm:pt-0 w-full"
      >
        <NavLink href="/" name="Projects" />
        <NavLink href="/about/" name="About" />
        <NavLink href="/music/" name="Music" />
        <NavLink href="/teaching/" name="Teaching" />
      </div>
    </div>
  </div>
</nav>

<style>
  .nav-load-in {
    opacity: 0;
    animation: navLoadIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes navLoadIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-load-in {
      animation: none;
      opacity: 1;
    }
  }
</style>
