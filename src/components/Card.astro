---
import CardLabel from "./Card-label.astro";

interface Props {
  href: string;
  title: string;
  types: { text: string; special: boolean }[];
  year: string;
  description?: string;
}

const { href, title, types, year, description = "" } = Astro.props;
---

<a
  class=`group flex flex-col col-span-6 md:col-span-3 2xl:col-span-2 cursor-pointer bg-purewhite border-r border-b border-[#d6daff] card h-full`
  href={href}
>
  <div class="aspect-17/10 overflow-hidden w-full bg-white card-media">
    <slot />
  </div>
  <div class="p-4 flex-1">
    <CardLabel
      value={title}
      types={types}
      year={year}
      isLarge={false}
      description={description}
    />
  </div>
</a>

<style>
  .card {
    position: relative;
    /* Clip the slotted media to the card's (animating) corner radius */
    overflow: hidden;
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease,
      border-radius 0.25s ease;
    will-change: transform;
  }

  .card:hover {
    /* transform: scale(1.03); */
    /* border-radius: 0.5rem; */
    /* Soft even shadow like the old JS hover (--card-shadow-color #e0e0e0),
       a little more pronounced. */
    box-shadow: 0 6px 26px 7px var(--card-shadow-color);
    z-index: 60;
  }

  /* Make every slotted image/video fill the fixed-aspect frame uniformly */
  .card-media > :global(div) {
    height: 100%;
  }

  .card-media :global(img),
  .card-media :global(video) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
</style>
