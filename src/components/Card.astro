---
import CardLabel from "./Card-label.astro";

interface Props {
  href: string;
  title: string;
  types: { text: string; special: boolean }[];
  year: string;
  description?: string;
}

const { href, title, types, year, description = "" } = Astro.props;
---

<a
  class=`group flex flex-col col-span-6 md:col-span-3 cursor-pointer bg-purewhite card h-full`
  href={href}
>
  <div class="md:aspect-18/10 overflow-hidden w-full bg-white card-media">
    <slot />
  </div>
  <div class="py-4 flex-1">
    <CardLabel
      value={title}
      types={types}
      year={year}
      isLarge={false}
      description={description}
    />
  </div>
</a>

<script>
  import "../scripts/card-cursor.js";
</script>

<style>
  .card {
    position: relative;
    overflow: hidden;
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease,
      border-radius 0.25s ease;
    will-change: transform;
  }

  .card:hover {
    z-index: 60;
  }

  .card-media > :global(div) {
    height: auto;
  }

  .card-media :global(img),
  .card-media :global(video) {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (min-width: 768px) {
    .card-media > :global(div) {
      height: 100%;
    }

    .card-media :global(img),
    .card-media :global(video) {
      height: 100%;
      object-fit: cover;
    }
  }
</style>
