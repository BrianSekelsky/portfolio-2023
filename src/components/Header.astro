<style>
  /* .header-card styles are now in Layout.astro for shared use */

  /* Ensure canvas fills the header properly */
  #header {
    box-sizing: border-box;
    position: relative;
    background: #ffffff;
  }

  #header :global(canvas) {
    display: block;
    border-radius: inherit;
  }

  /* Loading state - reversed colors */
  .header-loading {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    gap: 2rem;
    z-index: 1;
    background: #0a0a1a;
    border-radius: inherit;
    transition: opacity 0.5s ease-out;
  }

  .header-loading.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .header-loading-text {
    font-family:
      "neue-haas-grotesk",
      -apple-system,
      sans-serif;
    font-weight: 400;
    font-size: 1.125rem;
    line-height: 1.5;
    text-align: center;
    max-width: 480px;
    color: rgba(255, 255, 255, 0.7);
  }

  @media (min-width: 1024px) {
    .header-loading-text {
      font-size: 1.25rem;
    }
  }

  /* Spinner */
  .header-spinner {
    width: 48px;
    height: 48px;
    border: 4px solid transparent;
    border-top-color: rgba(255, 255, 255, 0.5);
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* Dark mode - already dark, so no change needed */
  :global(.dark) .header-loading {
    background: #0a0a1a;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Mobile dark header */
  .header-mobile {
    background: #0a0a1a;
    padding: 2rem;
  }

  .header-mobile-text {
    font-family: "freighttextcmp-pro", Georgia, serif;
    /* font-style: italic; */
    font-weight: 300;
    font-size: 1.75rem;
    line-height: 1.4;
    text-align: center;
    max-width: 400px;
    color: rgba(255, 255, 255, 0.7);
  }

  /* Only nudge on lg screens and above (Tailwind lg = 1024px) */
  @media (min-width: 1024px) {
    .translate {
      transform: translateX(-2px);
    }
  }
</style>
