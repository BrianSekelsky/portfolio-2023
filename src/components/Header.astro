---
---

<div class="transition-all duration-500 site-padding">
  <!-- Mobile: Static text in card -->
  <div
    class="flex items-center justify-center md:hidden min-h-[40vh] header-card"
    id="header-mobile"
  >
    <p class="text-5xl italic font-serif font-thin text-center light leading-[1.1] p-8">
      Brian Sekelsky is a designer, working across user experience, visual design, and code.
    </p>
  </div>

  <!-- Desktop: p5.js sketch in card -->
  <div
    class="hidden md:block min-h-[600px] max-w-full header-card"
    id="header"
  >
    <!-- Loading state - shows while sketch initializes -->
    <div id="header-loading" class="header-loading">
      <p class="header-loading-text">
        Brian Sekelsky is a designer, working across user experience, visual design, and code.
      </p>
    </div>
    <p class="sr-only">
      Brian Sekelsky is a designer, working across user experience, visual design, and code.
    </p>
  </div>
</div>

<script type="module" is:inline>
  // Only load sketch on desktop
  if (window.innerWidth >= 768) {
    import('/scripts/header-sketch.js');
  }
</script>

<style>
  /* .header-card styles are now in Layout.astro for shared use */

  /* Ensure canvas fills the header properly */
  #header {
    box-sizing: border-box;
    position: relative;
  }

  #header :global(canvas) {
    display: block;
    border-radius: inherit;
  }

  /* Loading state */
  .header-loading {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    z-index: 1;
    transition: opacity 0.4s ease-out;
  }

  .header-loading.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .header-loading-text {
    font-family: 'freight-text-pro', Georgia, serif;
    font-style: italic;
    font-weight: 300;
    font-size: 2.75rem;
    line-height: 1.15;
    text-align: center;
    max-width: 85%;
    color: #ccc;
    animation: pulse 2s ease-in-out infinite;
  }

  /* Scale up at larger breakpoints to match sketch sizing */
  @media (min-width: 900px) {
    .header-loading-text {
      font-size: 3.25rem;
      max-width: 80%;
    }
  }

  @media (min-width: 1100px) {
    .header-loading-text {
      font-size: 3.75rem;
      max-width: 75%;
    }
  }

  @media (min-width: 1400px) {
    .header-loading-text {
      font-size: 4.5rem;
      max-width: 70%;
    }
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.7; }
  }

  :global(.dark) .header-loading-text {
    color: #333;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
