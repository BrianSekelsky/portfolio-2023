---
---

<div class="transition-all duration-500 site-padding">
  <!-- Mobile: Static dark card -->
  <div class="flex items-center justify-center md:hidden min-h-[40vh] header-card header-mobile">
    <p class="header-mobile-text">
      Brian Sekelsky is a designer, working across user experience, visual design, and code.
    </p>
  </div>

  <!-- Desktop: p5.js sketch in card -->
  <div
    class="hidden md:block min-h-[600px] max-w-full header-card"
    id="header"
  >
    <!-- Loading state - shows while sketch initializes -->
    <div id="header-loading" class="header-loading">
      <p class="header-loading-text">
        Brian Sekelsky is a designer, working across user experience, visual design, and code.
      </p>
      <div class="header-spinner"></div>
    </div>
    <p class="sr-only">
      Brian Sekelsky is a designer, working across user experience, visual design, and code.
    </p>
  </div>
</div>

<script type="module" is:inline>
  // Load sketch on all screen sizes
  import('/scripts/header-sketch.js');
</script>

<style>
  /* .header-card styles are now in Layout.astro for shared use */

  /* Ensure canvas fills the header properly */
  #header {
    box-sizing: border-box;
    position: relative;
    background: #FFFFFF;
  }

  #header :global(canvas) {
    display: block;
    border-radius: inherit;
  }

  /* Loading state - reversed colors */
  .header-loading {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    gap: 2rem;
    z-index: 1;
    background: #0a0a1a;
    border-radius: inherit;
    transition: opacity 0.5s ease-out;
  }

  .header-loading.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .header-loading-text {
    font-family: 'neue-haas-grotesk', -apple-system, sans-serif;
    font-weight: 400;
    font-size: 1.125rem;
    line-height: 1.5;
    text-align: center;
    max-width: 480px;
    color: rgba(255, 255, 255, 0.7);
  }

  @media (min-width: 1024px) {
    .header-loading-text {
      font-size: 1.25rem;
    }
  }

  /* Spinner */
  .header-spinner {
    width: 48px;
    height: 48px;
    border: 4px solid transparent;
    border-top-color: rgba(255, 255, 255, 0.5);
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Dark mode - already dark, so no change needed */
  :global(.dark) .header-loading {
    background: #0a0a1a;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Mobile dark header */
  .header-mobile {
    background: #0a0a1a;
    padding: 2rem;
  }

  .header-mobile-text {
    font-family: 'freighttextcmp-pro', Georgia, serif;
    font-style: italic;
    font-weight: 300;
    font-size: 1.75rem;
    line-height: 1.4;
    text-align: center;
    max-width: 400px;
    color: rgba(255, 255, 255, 0.7);
  }
</style>
