<div class="min-h-[400px] max-w-full header-card border-bottom" id="header">
  <div class="header-text">
    <h1
      class="text-4xl md:text-5xl font-serif font-extralight text-black w-4/7 tracking-tight leading-12"
    >
      <p>
        Hello, I’m an NYC-based designer working across user experience and
        code. I’m currently a Senior UX Designer at Fidelity Investments.
      </p>
    </h1>
  </div>

  <script>
    import "../scripts/header-sketch.js";
    import "../scripts/header-cursor.js";
  </script>

  <style>
    #header {
      box-sizing: border-box;
      position: relative;
      background: #ffffff;
      overflow: hidden;
      border-bottom: 1px solid var(--border-color);
    }

    #header :global(canvas) {
      display: block;
      border-radius: inherit;
    }

    /* Text sits on top of the canvas */
    .header-text {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      min-height: 300px;
      padding: 2rem;
      /* width: 75%; */
      pointer-events: none;
      /* Thin white stroke behind the glyphs to separate the text from the
         sketch. paint-order draws the stroke first so it reads as a halo. */
      -webkit-text-stroke: 2px #ffffff;
      paint-order: stroke fill;
    }

